platform :ios, '13.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Load Flutter's CocoaPods helper methods (resolved from FLUTTER_ROOT in CI)
flutter_root = ENV['FLUTTER_ROOT']
raise 'FLUTTER_ROOT not set. Please ensure Flutter is installed and FLUTTER_ROOT is exported.' if flutter_root.nil? || flutter_root.empty?
require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
